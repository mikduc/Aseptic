# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, ollama
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Application Settings
DEBUG=false
MAX_FILE_SIZE_MB=100
SAMPLE_ROWS=5
MAX_EXECUTION_SECONDS=8
